{
  "name": "sutures",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "Breakpoints for AI Agents — Open-source visual debugger with live intervention for multi-agent systems",
  "author": "Anup Karanjkar",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/anupmaster/sutures.git"
  },
  "type": "module",
  "bin": {
    "sutures": "./bin/sutures.js"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "collector": "node packages/collector/dist/index.js",
    "dashboard": "apps/dashboard/node_modules/.bin/next start apps/dashboard -p 9472",
    "simulate": "python3 examples/playground/simulate.py"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.4.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
